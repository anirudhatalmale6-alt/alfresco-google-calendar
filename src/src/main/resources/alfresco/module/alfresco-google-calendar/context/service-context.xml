<?xml version='1.0' encoding='UTF-8'?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
         http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd">

    <bean class="org.springframework.context.support.PropertySourcesPlaceholderConfigurer">
        <property name="locations">
            <list>
                <value>classpath:alfresco-global.properties</value>
            </list>
        </property>
        <property name="ignoreUnresolvablePlaceholders" value="true"/>
        <property name="ignoreResourceNotFound" value="true"/>
        <property name="order" value="10"/>
    </bean>

    <!-- Google Calendar Service -->
    <bean id="googleCalendarService" class="org.iurit.alfresco.google.calendar.GoogleCalendarService"
          init-method="init">
        <property name="nodeService" ref="NodeService"/>
        <property name="siteService" ref="SiteService"/>
        <property name="clientId" value="${google.calendar.clientId:}"/>
        <property name="clientSecret" value="${google.calendar.clientSecret:}"/>
        <property name="redirectUri" value="${google.calendar.redirectUri:}"/>
    </bean>

    <!-- Calendar Event Sync Policy (Alfresco -> Google) -->
    <bean id="googleCalendarEventPolicy" class="org.iurit.alfresco.google.calendar.CalendarEventPolicy"
          init-method="init">
        <property name="policyComponent" ref="policyComponent"/>
        <property name="nodeService" ref="NodeService"/>
        <property name="googleCalendarService" ref="googleCalendarService"/>
    </bean>

    <!-- Reverse Sync Job: Google -> Alfresco (every 5 minutes) -->
    <bean id="googleCalendarSyncScheduler" class="org.springframework.scheduling.quartz.SchedulerAccessorBean">
        <property name="scheduler" ref="schedulerFactory"/>
        <property name="triggers">
            <list>
                <ref bean="googleCalendarSyncTrigger"/>
            </list>
        </property>
    </bean>

    <bean id="googleCalendarSyncTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
        <property name="cronExpression" value="${google.calendar.syncCron:0 */5 * * * ?}"/>
        <property name="startDelay" value="120000"/>
        <property name="jobDetail">
            <bean class="org.springframework.scheduling.quartz.JobDetailFactoryBean">
                <property name="jobClass" value="org.iurit.alfresco.google.calendar.GoogleCalendarSyncJob"/>
                <property name="durability" value="true"/>
                <property name="jobDataAsMap">
                    <map>
                        <entry key="googleCalendarService" value-ref="googleCalendarService"/>
                    </map>
                </property>
            </bean>
        </property>
    </bean>

    <!-- Web Scripts -->
    <bean id="webscript.org.iurit.google.google-calendar-auth.get"
          class="org.iurit.alfresco.google.calendar.GoogleCalendarAuthWebScript"
          parent="webscript">
        <property name="googleCalendarService" ref="googleCalendarService"/>
        <property name="siteService" ref="SiteService"/>
    </bean>

    <bean id="webscript.org.iurit.google.google-calendar-callback.get"
          class="org.iurit.alfresco.google.calendar.GoogleCalendarCallbackWebScript"
          parent="webscript">
        <property name="googleCalendarService" ref="googleCalendarService"/>
    </bean>

    <bean id="webscript.org.iurit.google.google-calendar-config.get"
          class="org.iurit.alfresco.google.calendar.GoogleCalendarConfigWebScript"
          parent="webscript">
        <property name="googleCalendarService" ref="googleCalendarService"/>
        <property name="siteService" ref="SiteService"/>
        <property name="nodeService" ref="NodeService"/>
    </bean>

    <bean id="webscript.org.iurit.google.google-calendar-config.post"
          class="org.iurit.alfresco.google.calendar.GoogleCalendarConfigPostWebScript"
          parent="webscript">
        <property name="googleCalendarService" ref="googleCalendarService"/>
        <property name="siteService" ref="SiteService"/>
    </bean>

</beans>
